# Local dev secrets — copy to `.dev.vars` (gitignored) and fill in.
# Production equivalents are Wrangler secrets:
#   bunx wrangler secret put BETTER_AUTH_SECRET
#   bunx wrangler secret put RESEND_API_KEY   (optional — without it the
#                                              magic link is logged to the
#                                              worker console instead)
# NOTE: `bun run cf-typegen` reads `.dev.vars` when generating
# `worker-configuration.d.ts`, so keep both keys present locally (an empty
# RESEND_API_KEY is fine) or the Env secret types will be dropped.

# Any long random string; sign/encrypt session material.
BETTER_AUTH_SECRET=""

# Resend API key; leave empty to use the console email fallback in dev.
RESEND_API_KEY=""

# IGDB (Twitch app) credentials for the add-by-name preview + straggler
# resolution (Stories 6.1/6.2). Same id/secret as the seed script's .env pair.
# The provider mints and refreshes its own Twitch app access token from the
# id+secret (Epic 5 stable-auth) — there is NO token to paste. OPTIONAL: when
# either is absent the games-DB search degrades to name-only adds.
# NOTE: these live in .dev.vars for the WORKER runtime; a copy in .env only
# feeds the Python seed scripts / Cloudflare CLI, not the running app.
# Production equivalents:
#   bunx wrangler secret put IGDB_CLIENT_ID
#   bunx wrangler secret put IGDB_CLIENT_SECRET
IGDB_CLIENT_ID=""
IGDB_CLIENT_SECRET=""

# Google OAuth (Story 8.1 / B1a) — "Continue with Google" alongside the magic
# link. OPTIONAL: when either is absent the provider is simply not registered
# and magic link is the only path (dev/e2e run this way). The allowlist still
# applies to the OAuth path — a non-AUTH_ALLOWED_EMAIL account is rejected
# before any user row is written. Redirect URI to register with Google:
#   https://<your-host>/api/auth/callback/google
# Production equivalents (secrets, never wrangler.jsonc vars):
#   bunx wrangler secret put GOOGLE_CLIENT_ID
#   bunx wrangler secret put GOOGLE_CLIENT_SECRET
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
