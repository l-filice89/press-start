# Environment for the one-time out-of-band seed import (`bun run seed`,
# Story 1.6). Copy to `.env` (gitignored) and fill in. These are NOT Worker
# runtime vars — the seed is a local Bun script, not the deployed Worker.

# --- IGDB enrichment (Twitch app credentials) ---
# Create a Twitch application (https://dev.twitch.tv/console/apps), then get a
# client-credentials access token:
#   curl -X POST "https://id.twitch.tv/oauth2/token?client_id=$IGDB_CLIENT_ID&client_secret=<secret>&grant_type=client_credentials"
IGDB_CLIENT_ID=""
IGDB_ACCESS_TOKEN=""

# --- Cloudflare D1 HTTP API (writes the seeded rows to the remote DB) ---
# Account id + the D1 database id (see wrangler.jsonc `d1_databases`) + an API
# token with D1 edit permission (https://dash.cloudflare.com/profile/api-tokens).
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_D1_DATABASE_ID="948f9dc7-498a-4bda-9467-f92b3405313c"
CLOUDFLARE_API_TOKEN=""

# --- Whose library this is ---
# Must match a `user` row (created on first magic-link sign-in). All tracking
# rows are scoped to this user.
SEED_USER_EMAIL="l.filice.89@gmail.com"

# --- Playwright e2e (optional) ---
# The e2e suite spawns its own server on 5175 by default; override only to
# point tests at a different port.
# BASE_URL="http://localhost:5175"
