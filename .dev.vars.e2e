# Playwright e2e secrets (CLOUDFLARE_ENV=e2e). Committed on purpose: this is
# a throwaway local-test value, NOT a real secret, and there is deliberately
# no RESEND_API_KEY here — its absence selects the console email provider so
# magic links print to stdout instead of sending real email (Epic 2.5 TR-1).
BETTER_AUTH_SECRET=e2e-local-only-secret-never-used-in-production

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Tests hammer the magic-link route by design; the in-code limiter is prod-only.
AUTH_RATE_LIMIT=off
